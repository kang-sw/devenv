#!/usr/bin/env bash
# review-path — emit temp paths for review findings files
#
# Usage: review-path <stem> [<stem> ...]
#   e.g. review-path correctness fit test
#
# Generates a pwd-scoped, per-call run-id so concurrent invocations
# across projects do not collide. Creates the parent directory if absent.
# Caller must capture all output lines from a single invocation —
# paths are not reproducible after the call returns.

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: review-path <stem> [<stem> ...]" >&2
  exit 1
fi

pwd_hash=$(printf '%s' "$PWD" | (sha1sum 2>/dev/null || shasum) | cut -c1-8)
run_id=$(set +o pipefail; LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c8)
dir="/tmp/claude-reviews"
mkdir -p "$dir"

for stem in "$@"; do
  safe_stem="${stem//[^a-zA-Z0-9_-]/-}"
  echo "${dir}/${pwd_hash}-${run_id}-${safe_stem}.md"
done
