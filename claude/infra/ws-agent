#!/usr/bin/env bash
# Generates a deterministic UUID v5 from repo root + git branch + agent name.
# Usage: ws-agent <name>
# Example: $(ws-agent implementer-1) → same UUID for same repo/branch/name

set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: ws-agent <name>" >&2
  exit 1
fi

NAME="$1"
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "no-git")

python3 - <<EOF
import uuid
ns = uuid.UUID('c0ffee00-dead-beef-cafe-000000000001')
print(uuid.uuid5(ns, '${REPO_ROOT}/${BRANCH}/${NAME}'))
EOF
