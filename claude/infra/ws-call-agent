#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 2 ]]; then
  echo "Usage: ws-call-agent <model> [--session-id <uuid>] [--uuid <session-id>] [--system-prompt <path>] <prompt>" >&2
  exit 1
fi

MODEL="$1"
shift

ARGS=(-p --dangerously-skip-permissions --output-format json --model "$MODEL")

while [[ $# -gt 1 ]]; do
  case "$1" in
    --session-id)
      ARGS+=(--session-id "$2")
      shift 2
      ;;
    --uuid)
      ARGS+=(--resume "$2")
      shift 2
      ;;
    --system-prompt)
      ARGS+=(--system-prompt "$(cat "$2")")
      shift 2
      ;;
    *)
      echo "Unknown flag: $1" >&2
      exit 1
      ;;
  esac
done

PROMPT="$1"

case "$MODEL" in
  claude*|sonnet|haiku|opus)
    claude "${ARGS[@]}" "$PROMPT"
    ;;
  gemini*)
    printf '{"type":"result","is_error":true,"result":"gemini routing not yet implemented"}\n' >&2
    exit 1
    ;;
  *)
    printf '{"type":"result","is_error":true,"result":"Unknown model: %s"}\n' "$MODEL" >&2
    exit 1
    ;;
esac
