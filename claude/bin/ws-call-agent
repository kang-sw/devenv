#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [[ $# -lt 2 ]]; then
  echo "Usage: ws-call-agent <model> [--agent <name>] [--session-id <uuid>] [--uuid <session-id>] [--system-prompt <path>] <prompt>" >&2
  exit 1
fi

MODEL="$1"
shift

ARGS=(-p --dangerously-skip-permissions --output-format json --model "$MODEL")

while [[ $# -gt 1 ]]; do
  case "$1" in
    --agent)
      UUID=$("$SCRIPT_DIR/ws-agent" "$2")
      ESCAPED=$(pwd | sed 's|/|-|g')
      SESSION_FILE="$HOME/.claude/projects/$ESCAPED/$UUID.jsonl"
      if [[ -f "$SESSION_FILE" ]]; then
        ARGS+=(--resume "$UUID")
      else
        ARGS+=(--session-id "$UUID")
      fi
      shift 2
      ;;
    --session-id)
      ARGS+=(--session-id "$2")
      shift 2
      ;;
    --uuid)
      ARGS+=(--resume "$2")
      shift 2
      ;;
    --system-prompt)
      ARGS+=(--system-prompt "$(cat "$2")")
      shift 2
      ;;
    *)
      echo "Unknown flag: $1" >&2
      exit 1
      ;;
  esac
done

PROMPT="$1"
CONTEXT_LIMIT=150000

TMPFILE=$(mktemp)
trap 'rm -f "$TMPFILE"' EXIT

case "$MODEL" in
  claude*|sonnet|haiku|opus)
    claude "${ARGS[@]}" "$PROMPT" > "$TMPFILE"
    ;;
  gemini*)
    echo "gemini routing not yet implemented" >&2
    exit 1
    ;;
  *)
    echo "Unknown model: $MODEL" >&2
    exit 1
    ;;
esac

CONTEXT_TOKENS=$(jq '.usage.input_tokens + .usage.cache_creation_input_tokens + .usage.cache_read_input_tokens' "$TMPFILE")
CONTEXT_PCT=$(python3 -c "print(round($CONTEXT_TOKENS / $CONTEXT_LIMIT * 100))")

if [[ "$CONTEXT_PCT" -ge 70 ]]; then
  echo "[warn] Context window: ${CONTEXT_PCT}% filled — recommended to refresh this agent"
else
  echo "[info] Context window: ${CONTEXT_PCT}% filled"
fi
echo ""

jq -r '.result' "$TMPFILE"

if [[ "$(jq -r '.is_error' "$TMPFILE")" == "true" ]]; then
  exit 1
fi
