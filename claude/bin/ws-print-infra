#!/usr/bin/env bash
# ws-print-infra — cat a shared infra doc by name, or list available resources.
# Works in both skill and agent contexts where $CLAUDE_PLUGIN_ROOT
# is unavailable (e.g. agent Bash tool calls).
#
# Usage:
#   ws-print-infra              list available infra docs and bin scripts
#   ws-print-infra <doc-name>   print the named infra doc

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
PLUGIN_ROOT="$(dirname "$SCRIPT_DIR")"

if [ $# -eq 0 ]; then
  echo "Infra docs (ws-print-infra <name>):"
  ls "${PLUGIN_ROOT}/infra/"*.md 2>/dev/null | while read -r f; do
    echo "  $(basename "$f")"
  done

  echo ""
  echo "Bin scripts:"
  ls "${PLUGIN_ROOT}/bin/" 2>/dev/null | while read -r f; do
    echo "  $f"
  done
  exit 0
fi

if [ $# -ne 1 ]; then
  echo "usage: ws-print-infra [<doc-name>]" >&2
  exit 2
fi

TARGET="${PLUGIN_ROOT}/infra/$1"

if [ ! -f "$TARGET" ] && [[ "$1" != *.md ]]; then
  TARGET="${PLUGIN_ROOT}/infra/$1.md"
fi

if [ ! -f "$TARGET" ]; then
  echo "ws-print-infra: not found: infra/$1" >&2
  exit 1
fi

cat "$TARGET"
