#!/usr/bin/env python3
"""ws-named-agent — unified agent orchestration tool."""

import atexit
import json
import os
import shutil
import subprocess
import sys
import tempfile
import time
import uuid as _uuid_mod
from dataclasses import dataclass
from pathlib import Path

SCRIPT_DIR = Path(os.path.realpath(__file__)).parent
PLUGIN_DIR = SCRIPT_DIR.parent
KNOWN_TIERS = {"opus", "sonnet", "haiku"}

# On Windows, `claude` and `codex` are .cmd files and cannot be exec'd without shell.
# Resolve once at import time; wrap with `cmd /c` when needed.
_CLAUDE_EXE = shutil.which("claude") or "claude"
_CODEX_EXE = shutil.which("codex") or "codex"

def _claude_exe() -> list[str]:
    if _CLAUDE_EXE.lower().endswith(".cmd"):
        return ["cmd", "/c", _CLAUDE_EXE]
    return [_CLAUDE_EXE]

def _codex_exe() -> list[str]:
    if _CODEX_EXE.lower().endswith(".cmd"):
        return ["cmd", "/c", _CODEX_EXE]
    return [_CODEX_EXE]
# Backend shorthand names: stored as model when no explicit model given.
# Never passed as --model to their respective CLIs; those CLIs use their own defaults.
_BACKEND_SHORTHANDS = frozenset({"claude", "codex", "gemini"})

# ── Registry helpers ──────────────────────────────────────────────────────────

def _git(arg):
    r = subprocess.run(["git", "rev-parse", arg], capture_output=True, text=True, encoding="utf-8")
    return r.stdout.strip() if r.returncode == 0 else None


def _registry_dir() -> Path:
    git_dir = _git("--git-dir")
    if git_dir is None:
        print("error: not in a git repository", file=sys.stderr)
        sys.exit(1)
    repo_root = _git("--show-toplevel") or os.getcwd()
    git_dir_path = Path(git_dir)
    if not git_dir_path.is_absolute():
        git_dir_path = Path.cwd() / git_dir_path
    return git_dir_path / f"ws@{Path(repo_root).name}" / "agents"


def _load_registry(registry_dir: Path, agent_name: str) -> dict:
    agent_file = registry_dir / f"{agent_name}.json"
    if not agent_file.exists():
        print(f"error: agent '{agent_name}' not found — run ws-named-agent new first", file=sys.stderr)
        sys.exit(1)
    with open(agent_file) as fh:
        return json.load(fh)


def _atomic_write(path: Path, data: dict) -> None:
    tmp = Path(str(path) + ".tmp")
    tmp.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
    tmp.replace(path)  # replace() is atomic and works when dest exists on Windows

# ── Cleanup ───────────────────────────────────────────────────────────────────

_cleanup_files: list[str] = []


def _cleanup() -> None:
    for p in _cleanup_files:
        try:
            os.unlink(p)
        except OSError:
            pass


atexit.register(_cleanup)


def _mktemp() -> str:
    fd, path = tempfile.mkstemp()
    os.close(fd)
    _cleanup_files.append(path)
    return path

# ── Backend resolution ────────────────────────────────────────────────────────

def infer_backend(model: str) -> str:
    m = model.lower()
    if "gemini" in m:
        return "gemini"
    if "codex" in m:
        return "codex"
    return "claude"


_PLUGIN_CONFIG_NAME = "kang-sw-devenv-ws.json"


def _global_config_path() -> Path:
    return Path.home() / ".claude" / _PLUGIN_CONFIG_NAME


def _local_config_path() -> Path:
    repo_root = _git("--show-toplevel") or os.getcwd()
    return Path(repo_root) / ".claude" / _PLUGIN_CONFIG_NAME


def _load_config_file(p: Path) -> dict:
    if not p.exists():
        return {}
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return {}


def _load_ws_config() -> dict:
    """Load merged config: global + local. Local wins on conflict."""
    merged = _load_config_file(_global_config_path())
    for k, v in _load_config_file(_local_config_path()).items():
        if isinstance(v, dict) and isinstance(merged.get(k), dict):
            merged[k] = {**merged[k], **v}
        else:
            merged[k] = v
    return merged


def resolve_model_backend(registry: dict) -> tuple[str, str]:
    """Return (model, backend) applying env var > config file > stored model."""
    tier = registry.get("tier")
    stored_model = registry.get("model") or "sonnet"

    if tier and tier in KNOWN_TIERS:
        override = os.environ.get(f"WS_OVERRIDE_{tier.upper()}")
        if not override:
            override = _load_ws_config().get("agent-overrides", {}).get(tier, "")
        if override:
            return override, infer_backend(override)

    backend = registry.get("backend") or infer_backend(stored_model)
    return stored_model, backend

# ── ws: agent file resolution ─────────────────────────────────────────────────

def _strip_frontmatter(text: str) -> str:
    if not text.startswith("---"):
        return text
    parts = text.split("---\n", 2)
    return parts[2].strip() if len(parts) >= 3 else text


def _frontmatter_field(text: str, field: str) -> str:
    """Extract a scalar field from YAML frontmatter (---...---). Returns '' if absent."""
    if not text.startswith("---"):
        return ""
    parts = text.split("---\n", 2)
    if len(parts) < 3:
        return ""
    for line in parts[1].splitlines():
        if line.startswith(f"{field}:"):
            return line[len(f"{field}:"):].strip()
    return ""


def _resolve_ws_agent(agent_type: str) -> str | None:
    """Resolve ws:<stem> to agent file body. Returns None if file not found."""
    if not agent_type.startswith("ws:"):
        return None
    stem = agent_type[3:]
    agent_file = PLUGIN_DIR / "agents" / f"{stem}.md"
    if not agent_file.exists():
        return None
    return _strip_frontmatter(agent_file.read_text(encoding="utf-8"))

# ── CallResult ────────────────────────────────────────────────────────────────

@dataclass
class CallResult:
    text: str
    is_error: bool
    tokens: int

# ── Claude backend ────────────────────────────────────────────────────────────

def _claude_tokens(data: dict) -> int:
    u = data.get("usage") or {}
    return (
        (u.get("input_tokens") or 0)
        + (u.get("cache_creation_input_tokens") or 0)
        + (u.get("output_tokens") or 0)
    )


def _settings_json() -> str:
    # Use absolute path so the hook works regardless of the hook shell's PATH
    cmd = f"{SCRIPT_DIR}/ws-named-agent check-mailbox"
    return json.dumps({
        "hooks": {
            "PostToolBatch": [{
                "hooks": [{
                    "type": "command",
                    "command": cmd,
                    "timeout": 5,
                }]
            }]
        }
    })


def _collect_claude_mds() -> str:
    """Collect CLAUDE.md files from git root down to CWD, outer-to-inner order."""
    repo_root = _git("--show-toplevel")
    if not repo_root:
        return ""
    root = Path(repo_root)
    cwd = Path.cwd()
    try:
        rel = cwd.relative_to(root)
        dirs = [root] + [root.joinpath(*rel.parts[:i + 1]) for i in range(len(rel.parts))]
    except ValueError:
        dirs = [root]
    chunks = []
    for d in dirs:
        f = d / "CLAUDE.md"
        if f.exists():
            chunks.append(f.read_text(encoding="utf-8").strip())
    return "\n\n".join(chunks)


def _call_claude(
    *,
    agent_name: str,
    model: str,
    agent_type: str,
    system_prompt: str,
    prompt: str,
    uuid: str,
    outbox_file: Path,
    skip_compression: bool,
    registry_dir: Path,
    registry: dict,
    **_,
) -> CallResult:
    settings = _settings_json()

    # Inject CLAUDE.md between the agent definition and the registered system prompt.
    claude_md = _collect_claude_mds()
    effective_sp = "\n\n---\n\n".join(p for p in [claude_md, system_prompt] if p)

    def _flags(for_model: str = "") -> list[str]:
        m = for_model or model
        flags = _claude_exe() + ["-p", "--dangerously-skip-permissions", "--output-format", "json"]
        if m:
            flags += ["--model", m]
        if agent_type:
            flags += ["--agent", agent_type]
        if effective_sp:
            flags += ["--system-prompt", effective_sp]
        flags += ["--settings", settings]
        return flags

    # Session routing: glob replaces Unix find for Windows portability
    matches = list((Path.home() / ".claude" / "projects").glob(f"*/{uuid}.jsonl"))
    find_out = str(matches[0]) if matches else ""

    args = _flags() + (["--resume", uuid] if find_out else ["--session-id", uuid])

    tmpfile = _mktemp()
    errfile = _mktemp()

    for attempt in range(1, 4):
        with open(tmpfile, "w", encoding="utf-8") as out, open(errfile, "w", encoding="utf-8") as err:
            ret = subprocess.run(args + [prompt], stdout=out, stderr=err)
        if ret.returncode == 0:
            break
        err_text = Path(errfile).read_text(encoding="utf-8")
        if "already in use" in err_text and attempt < 3:
            print(f"[info] Session busy, retrying in 3s (attempt {attempt}/3)...", file=sys.stderr)
            time.sleep(3)
        else:
            sys.stderr.write(err_text)
            sys.exit(1)

    # Drain loop: PostToolBatch hook exits 2 when outbox has content
    drain_args = _flags() + ["--resume", uuid]
    while outbox_file.stat().st_size > 0:
        pending = outbox_file.read_text(encoding="utf-8")
        outbox_file.write_text("", encoding="utf-8")
        drain_tmp = _mktemp()
        with open(drain_tmp, "w", encoding="utf-8") as out:
            subprocess.run(drain_args + [pending], stdout=out, check=True)
        shutil.copy2(drain_tmp, tmpfile)

    with open(tmpfile, encoding="utf-8") as fh:
        data = json.load(fh)
    tokens = _claude_tokens(data)
    text = data.get("result", "")
    is_error = data.get("is_error") is True

    registry["token_count"] = tokens
    registry["context-window"] = tokens
    _atomic_write(registry_dir / f"{agent_name}.json", registry)

    threshold = int(os.environ.get("WS_COMPRESS_THRESHOLD", "120000"))
    if tokens > threshold and not skip_compression:
        print("[info] Context threshold exceeded — compressing session...", file=sys.stderr)

        # Step a: intent summary via haiku
        intent_file = _mktemp()
        with open(intent_file, "w", encoding="utf-8") as out:
            subprocess.run(
                _claude_exe() + [
                    "-p", "--dangerously-skip-permissions",
                    "--output-format", "json", "--model", "haiku",
                    "--system-prompt", "Summarize the user's intent in 2-3 sentences. Do not perform the task.",
                    prompt,
                ], stdout=out, check=True)
        with open(intent_file, encoding="utf-8") as fh:
            intent_summary = json.load(fh).get("result", "")

        # Step b: inject compression prompt into existing session
        compression_path = subprocess.run(
            ["ws-infra-path", "agent-compression.md"],
            capture_output=True, text=True, encoding="utf-8", check=True,
        ).stdout.strip()
        compression_prompt = Path(compression_path).read_text(encoding="utf-8")

        comp_file = _mktemp()
        with open(comp_file, "w", encoding="utf-8") as out:
            subprocess.run(_flags() + ["--resume", uuid] + [compression_prompt], stdout=out, check=True)
        with open(comp_file, encoding="utf-8") as fh:
            compression_doc = json.load(fh).get("result", "")

        # Step c: snapshot outbox, re-register with fresh UUID, restore outbox
        saved_outbox = outbox_file.read_text(encoding="utf-8") if outbox_file.stat().st_size > 0 else ""

        new_args = ["ws-named-agent", "new", agent_name]
        if model:
            new_args += ["--model", model]
        if agent_type:
            new_args += ["--agent-type", agent_type]
        if system_prompt:
            sp_file = _mktemp()
            Path(sp_file).write_text(system_prompt, encoding="utf-8")
            new_args += ["--system-prompt", sp_file]
        subprocess.run(new_args, check=True)

        with open(registry_dir / f"{agent_name}.json") as fh:
            new_reg = json.load(fh)
        new_uuid = new_reg["uuid"]
        new_reg["compressed_at"] = True
        _atomic_write(registry_dir / f"{agent_name}.json", new_reg)

        if saved_outbox:
            outbox_file.write_text(saved_outbox, encoding="utf-8")

        # Step d: handoff to fresh session
        handoff_prompt = f"{compression_doc}\n\n---\n\n{intent_summary}\n\n---\n\n{prompt}"
        handoff_file = _mktemp()
        with open(handoff_file, "w", encoding="utf-8") as out:
            subprocess.run(_flags() + ["--session-id", new_uuid] + [handoff_prompt], stdout=out, check=True)
        with open(handoff_file, encoding="utf-8") as fh:
            h_data = json.load(fh)
        h_tokens = _claude_tokens(h_data)

        with open(registry_dir / f"{agent_name}.json") as fh:
            new_reg = json.load(fh)
        new_reg["token_count"] = h_tokens
        new_reg["context-window"] = h_tokens
        _atomic_write(registry_dir / f"{agent_name}.json", new_reg)

        return CallResult(text=h_data.get("result", ""), is_error=h_data.get("is_error") is True, tokens=h_tokens)

    return CallResult(text=text, is_error=is_error, tokens=tokens)

# ── Codex backend ────────────────────────────────────────────────────────────

def _codex_parse_jsonl(raw: str) -> list[dict]:
    events = []
    for line in raw.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            events.append(json.loads(line))
        except json.JSONDecodeError:
            pass
    return events


def _codex_tokens(events: list[dict]) -> int:
    for event in reversed(events):
        if event.get("type") == "turn.completed":
            u = event.get("usage") or {}
            return (
                (u.get("input_tokens") or 0)
                + (u.get("cached_input_tokens") or 0)
                + (u.get("output_tokens") or 0)
            )
    return 0


def _codex_result_text(events: list[dict]) -> str:
    text = ""
    for event in events:
        if event.get("type") == "item.completed":
            item = event.get("item") or {}
            if item.get("type") == "agent_message":
                text = item.get("text", "")
    return text


def _codex_thread_id(events: list[dict]) -> str:
    for event in events:
        if event.get("type") == "thread.started":
            return event.get("thread_id", "")
    return ""


def _call_codex(
    *,
    agent_name: str,
    model: str,
    agent_type: str,
    system_prompt: str,
    prompt: str,
    uuid: str,
    outbox_file: Path,
    skip_compression: bool,
    registry_dir: Path,
    registry: dict,
    **_,
) -> CallResult:
    # Combine ws: agent body with registry system_prompt
    effective_sp = system_prompt
    if agent_type and agent_type.startswith("ws:"):
        body = _resolve_ws_agent(agent_type)
        if body:
            effective_sp = (body + "\n\n---\n\n" + system_prompt).strip() if system_prompt else body

    # Write system prompt once; reuse across all calls in this invocation
    sp_file = ""
    if effective_sp:
        sp_file = _mktemp()
        Path(sp_file).write_text(effective_sp, encoding="utf-8")

    def _base_flags() -> list[str]:
        flags = ["--dangerously-bypass-approvals-and-sandbox", "--json"]
        if model and model not in _BACKEND_SHORTHANDS:
            flags += ["--model", model]
        check_cmd = f"{SCRIPT_DIR}/ws-named-agent check-mailbox"
        # TOML inline-table syntax required; json.dumps for string quoting is compatible
        hook_toml = f'[{{hooks=[{{type="command",command={json.dumps(check_cmd)},timeout=5}}]}}]'
        flags += ["-c", "features.codex_hooks=true", "-c", f"hooks.PostToolUse={hook_toml}"]
        if sp_file:
            flags += ["-c", f"model_instructions_file={json.dumps(sp_file)}"]
        return flags

    def _run(p: str, thread_id: str = "") -> list[dict]:
        base = _base_flags()
        if thread_id:
            cmd = _codex_exe() + ["exec", "resume"] + base + [thread_id, p]
        else:
            cmd = _codex_exe() + ["exec"] + base + [p]
        r = subprocess.run(cmd, capture_output=True, text=True, encoding="utf-8", stdin=subprocess.DEVNULL)
        events = _codex_parse_jsonl(r.stdout)
        if r.returncode != 0 and not events:
            sys.stderr.write(r.stderr)
            sys.exit(1)
        return events

    # Session routing: rglob replaces Unix find for Windows portability
    codex_matches = list((Path.home() / ".codex" / "sessions").rglob(f"rollout-*-{uuid}.jsonl"))
    find_out = str(codex_matches[0]) if codex_matches else ""

    events = _run(prompt, uuid if find_out else "")

    # First call: codex assigns thread_id — overwrite registry uuid
    thread_id = _codex_thread_id(events)
    if not find_out and thread_id and thread_id != uuid:
        registry["uuid"] = thread_id
        uuid = thread_id

    # Drain loop: PostToolUse hook exits 2 when outbox has content
    while outbox_file.stat().st_size > 0:
        pending = outbox_file.read_text(encoding="utf-8")
        outbox_file.write_text("", encoding="utf-8")
        events = _run(pending, uuid)

    tokens = _codex_tokens(events)
    text = _codex_result_text(events)

    registry["token_count"] = tokens
    registry["context-window"] = tokens
    _atomic_write(registry_dir / f"{agent_name}.json", registry)

    threshold = int(os.environ.get("WS_COMPRESS_THRESHOLD", "120000"))
    if tokens > threshold and not skip_compression:
        print("[info] Context threshold exceeded — compressing session...", file=sys.stderr)

        # Step a: intent summary via claude haiku (backend-agnostic helper)
        intent_file = _mktemp()
        with open(intent_file, "w", encoding="utf-8") as out:
            subprocess.run(
                _claude_exe() + ["-p", "--dangerously-skip-permissions",
                "--output-format", "json", "--model", "haiku",
                "--system-prompt", "Summarize the user's intent in 2-3 sentences. Do not perform the task.",
                prompt,
            ], stdout=out, check=True)
        with open(intent_file, encoding="utf-8") as fh:
            intent_summary = json.load(fh).get("result", "")

        # Step b: inject compression prompt into existing codex session
        compression_path = subprocess.run(
            ["ws-infra-path", "agent-compression.md"],
            capture_output=True, text=True, encoding="utf-8", check=True,
        ).stdout.strip()
        compression_prompt = Path(compression_path).read_text(encoding="utf-8")
        comp_events = _run(compression_prompt, uuid)
        compression_doc = _codex_result_text(comp_events)

        # Step c: snapshot outbox, re-register with fresh uuid, restore outbox
        saved_outbox = outbox_file.read_text(encoding="utf-8") if outbox_file.stat().st_size > 0 else ""

        new_args = ["ws-named-agent", "new", agent_name]
        if model:
            new_args += ["--model", model]
        if agent_type:
            new_args += ["--agent-type", agent_type]
        if effective_sp:
            sp_tmp = _mktemp()
            Path(sp_tmp).write_text(effective_sp, encoding="utf-8")
            new_args += ["--system-prompt", sp_tmp]
        subprocess.run(new_args, check=True)

        with open(registry_dir / f"{agent_name}.json") as fh:
            new_reg = json.load(fh)
        new_reg["compressed_at"] = True
        _atomic_write(registry_dir / f"{agent_name}.json", new_reg)

        if saved_outbox:
            outbox_file.write_text(saved_outbox, encoding="utf-8")

        # Step d: handoff to fresh codex session — thread_id assigned at runtime
        handoff_prompt = f"{compression_doc}\n\n---\n\n{intent_summary}\n\n---\n\n{prompt}"
        handoff_events = _run(handoff_prompt, "")

        new_thread_id = _codex_thread_id(handoff_events)
        with open(registry_dir / f"{agent_name}.json") as fh:
            new_reg = json.load(fh)
        if new_thread_id:
            new_reg["uuid"] = new_thread_id
        h_tokens = _codex_tokens(handoff_events)
        new_reg["token_count"] = h_tokens
        new_reg["context-window"] = h_tokens
        _atomic_write(registry_dir / f"{agent_name}.json", new_reg)

        return CallResult(text=_codex_result_text(handoff_events), is_error=False, tokens=h_tokens)

    return CallResult(text=text, is_error=False, tokens=tokens)


# ── Non-claude stubs ──────────────────────────────────────────────────────────

def _call_gemini(**_) -> CallResult:
    print("error: gemini backend not yet implemented", file=sys.stderr)
    sys.exit(1)


BACKENDS = {
    "claude": _call_claude,
    "gemini": _call_gemini,
    "codex":  _call_codex,
}

# ── Subcommands ───────────────────────────────────────────────────────────────

def cmd_new(argv: list[str]) -> None:
    if not argv:
        print("Usage: ws-named-agent new <name> [--model M] [--system-prompt P] [--agent-type T]", file=sys.stderr)
        sys.exit(1)

    agent_name = argv[0]
    model_arg: str | None = None
    system_prompt_path = ""
    agent_type = ""
    agent_type_set = False

    i = 1
    while i < len(argv):
        if argv[i] == "--model":
            model_arg = argv[i + 1]; i += 2
        elif argv[i] == "--system-prompt":
            system_prompt_path = argv[i + 1]; i += 2
        elif argv[i] in ("--agent-type", "--agent"):
            agent_type = argv[i + 1]; agent_type_set = True; i += 2
        else:
            print(f"Unknown flag: {argv[i]}", file=sys.stderr); sys.exit(1)

    # Step 1: read tier from agent frontmatter (ws: agents only)
    fm_tier: str | None = None
    if agent_type and agent_type.startswith("ws:"):
        stem = agent_type[3:]
        agent_file = PLUGIN_DIR / "agents" / f"{stem}.md"
        if agent_file.exists():
            fm_model = _frontmatter_field(agent_file.read_text(encoding="utf-8"), "model")
            if fm_model in KNOWN_TIERS:
                fm_tier = fm_model

    # Step 2: --model arg overrides frontmatter; no arg falls back to frontmatter or defaults
    if model_arg is None:
        if fm_tier:
            model = fm_tier
            tier: str | None = fm_tier
        elif agent_type_set:
            model = ""
            tier = None
        else:
            default = _load_ws_config().get("default-model", "")
            model = default if default else "sonnet"
            tier = model if model in KNOWN_TIERS else None
    elif model_arg in KNOWN_TIERS:
        model = model_arg
        tier = model_arg
    else:
        model = model_arg
        tier = None

    backend = infer_backend(model) if model else "claude"
    system_prompt = Path(system_prompt_path).read_text(encoding="utf-8") if system_prompt_path else ""

    registry_dir = _registry_dir()
    registry_dir.mkdir(parents=True, exist_ok=True)

    data: dict = {
        "uuid": str(_uuid_mod.uuid4()),
        "tier": tier,
        "model": model,
        "backend": backend,
        "agent_type": agent_type,
        "system_prompt": system_prompt,
        "token_count": 0,
        "compressed_at": False,
    }
    _atomic_write(registry_dir / f"{agent_name}.json", data)

    outbox = registry_dir / f"{agent_name}.outbox.txt"
    with open(outbox, "a"):
        pass

    print(f"Agent '{agent_name}' registered")


def cmd_call(argv: list[str]) -> None:
    if not argv:
        print("Usage: ws-named-agent call <name> <prompt>", file=sys.stderr)
        sys.exit(1)

    agent_name = argv[0]
    prompt = sys.stdin.read() if len(argv) < 2 or argv[1] == "-" else argv[1]

    registry_dir = _registry_dir()
    registry = _load_registry(registry_dir, agent_name)

    uuid = registry.get("uuid", "")
    agent_type = registry.get("agent_type") or ""
    system_prompt = registry.get("system_prompt") or ""
    model, backend = resolve_model_backend(registry)

    skip_compression = False
    if registry.get("compressed_at") is True:
        registry["compressed_at"] = False
        _atomic_write(registry_dir / f"{agent_name}.json", registry)
        skip_compression = True

    outbox_file = registry_dir / f"{agent_name}.outbox.txt"
    outbox_file.parent.mkdir(parents=True, exist_ok=True)
    with open(outbox_file, "a"):
        pass
    os.environ["WS_AGENT_OUTBOX"] = str(outbox_file)

    # Agent type resolution for non-claude backends
    effective_agent_type = agent_type
    if backend != "claude" and agent_type:
        if agent_type.startswith("ws:"):
            body = _resolve_ws_agent(agent_type)
            if body is None:
                print(f"[warn] ws: agent '{agent_type}' not found in {PLUGIN_DIR}/agents/", file=sys.stderr)
            # body will be used by the backend implementation when it exists
        else:
            print(
                f"[warn] agent type '{agent_type}' is not a ws: agent — "
                f"not supported on {backend} backend; use ws-subquery for one-shot queries",
                file=sys.stderr,
            )
            effective_agent_type = ""

    fn = BACKENDS.get(backend)
    if fn is None:
        print(f"error: unknown backend '{backend}'", file=sys.stderr)
        sys.exit(1)

    result = fn(
        agent_name=agent_name,
        model=model,
        agent_type=effective_agent_type,
        system_prompt=system_prompt,
        prompt=prompt,
        uuid=uuid,
        outbox_file=outbox_file,
        skip_compression=skip_compression,
        registry_dir=registry_dir,
        registry=registry,
    )

    output_path = registry_dir / f"{agent_name}.output.txt"
    out_text = result.text if result.text.endswith("\n") else result.text + "\n"
    output_path.write_text(out_text, encoding="utf-8")
    print(result.text)

    if result.is_error:
        sys.exit(1)


def cmd_interrupt(argv: list[str]) -> None:
    if len(argv) < 2:
        print("Usage: ws-named-agent interrupt <name> <message>", file=sys.stderr)
        sys.exit(1)

    agent_name = argv[0]
    message = sys.stdin.read() if argv[1] == "-" else argv[1]

    registry_dir = _registry_dir()
    if not (registry_dir / f"{agent_name}.json").exists():
        print(f"error: agent '{agent_name}' not found — run ws-named-agent new first", file=sys.stderr)
        sys.exit(1)

    with open(registry_dir / f"{agent_name}.outbox.txt", "a") as fh:
        fh.write(message)
    print(f"Message queued for agent '{agent_name}'")


def cmd_print(argv: list[str]) -> None:
    if not argv:
        print("Usage: ws-named-agent print <name>", file=sys.stderr)
        sys.exit(1)

    agent_name = argv[0]
    output_path = _registry_dir() / f"{agent_name}.output.txt"
    if not output_path.exists():
        print(f"error: no output found for agent '{agent_name}'", file=sys.stderr)
        sys.exit(1)
    print(output_path.read_text(encoding="utf-8"), end="")


def cmd_check_mailbox(_argv: list[str]) -> None:
    outbox = os.environ.get("WS_AGENT_OUTBOX", "")
    if not outbox:
        sys.exit(0)
    p = Path(outbox)
    sys.exit(2 if p.exists() and p.stat().st_size > 0 else 0)


def cmd_override(argv: list[str]) -> None:
    if not argv or argv[0] == "show":
        gp, lp = _global_config_path(), _local_config_path()
        gcfg, lcfg = _load_config_file(gp), _load_config_file(lp)
        print(f"# global: {gp}")
        print(json.dumps(gcfg, indent=2) if gcfg else "(empty)")
        print(f"# local:  {lp}")
        print(json.dumps(lcfg, indent=2) if lcfg else "(empty)")
        return

    global_flag = argv[0] == "-g"
    if global_flag:
        argv = argv[1:]

    if len(argv) < 2:
        print("Usage: ws-named-agent override [-g] <tier> <model>", file=sys.stderr)
        print("       ws-named-agent override [-g] default <model>", file=sys.stderr)
        print("       ws-named-agent override [-g] <tier>|default --unset", file=sys.stderr)
        print("       ws-named-agent override show", file=sys.stderr)
        sys.exit(1)

    tier, value = argv[0], argv[1]
    p = _global_config_path() if global_flag else _local_config_path()
    cfg = _load_config_file(p)
    p.parent.mkdir(parents=True, exist_ok=True)

    if tier == "default":
        if value == "--unset":
            cfg.pop("default-model", None)
            _atomic_write(p, cfg)
            print(f"Removed default model  ({p})")
        else:
            cfg["default-model"] = value
            _atomic_write(p, cfg)
            print(f"Set default model → {value}  ({p})")
        return

    if tier not in KNOWN_TIERS:
        print(f"error: tier must be one of {sorted(KNOWN_TIERS)} or 'default'", file=sys.stderr)
        sys.exit(1)

    overrides: dict = cfg.setdefault("agent-overrides", {})
    if value == "--unset":
        overrides.pop(tier, None)
        if not overrides:
            cfg.pop("agent-overrides", None)
        _atomic_write(p, cfg)
        print(f"Removed override for '{tier}'  ({p})")
    else:
        overrides[tier] = value
        _atomic_write(p, cfg)
        print(f"Set {tier} → {value}  ({p})")


def _tail_claude(session_path: Path, n: int) -> None:
    lines = session_path.read_text(encoding="utf-8").splitlines()

    # Each assistant line holds exactly one content block; group by message ID.
    msg_order: list[tuple[str, object]] = []   # ("assistant", mid) | ("tool_results", count) | ("user_prompt", text)
    msg_data: dict[str, dict] = {}             # mid → {texts, tools}
    seen_mids: set[str] = set()

    for raw in lines:
        try:
            obj = json.loads(raw)
        except json.JSONDecodeError:
            continue
        t = obj.get("type")
        if t == "assistant":
            msg = obj.get("message", {})
            mid = msg.get("id", "")
            if not mid:
                continue
            if mid not in seen_mids:
                seen_mids.add(mid)
                msg_order.append(("assistant", mid))
                msg_data[mid] = {"texts": [], "tools": []}
            for block in msg.get("content", []):
                bt = block.get("type")
                if bt == "text":
                    msg_data[mid]["texts"].append(block.get("text", ""))
                elif bt == "tool_use":
                    msg_data[mid]["tools"].append(block.get("name", "?"))
        elif t == "user":
            msg = obj.get("message", {})
            content = msg.get("content", [])
            if not isinstance(content, list) or not content:
                continue
            if any(isinstance(b, dict) and b.get("type") == "tool_result" for b in content):
                count = sum(1 for b in content if isinstance(b, dict) and b.get("type") == "tool_result")
                msg_order.append(("tool_results", count))
            else:
                text = next(
                    (b.get("text", "") for b in content if isinstance(b, dict) and b.get("type") == "text"),
                    str(content[0])[:80] if content else "",
                )
                msg_order.append(("user_prompt", text[:80]))

    # Find the last N assistant turns and include surrounding context.
    assistant_positions = [i for i, (kind, _) in enumerate(msg_order) if kind == "assistant"]
    if not assistant_positions:
        print("(no assistant turns found in session)")
        return
    start = assistant_positions[-n] if len(assistant_positions) >= n else 0
    recent = msg_order[start:]

    total = len(recent)
    for idx, (kind, data) in enumerate(recent):
        offset = idx - total + 1
        label = f"[{offset:+d}]" if offset != 0 else "[last]"
        if kind == "assistant":
            mid = data
            d = msg_data[mid]
            text = " ".join(d["texts"])
            preview = repr(text[:120]) if text else "(no text)"
            tools = d["tools"]
            tool_str = f"  tools: {' '.join(tools)}" if tools else ""
            print(f"{label} assistant: {preview}{tool_str}")
        elif kind == "tool_results":
            print(f"{label} tool-results: {data} returned")
        elif kind == "user_prompt":
            print(f"{label} user: {repr(data)}")


def _tail_codex(session_path: Path, n: int) -> None:
    # Session file uses {"timestamp":...,"type":...,"payload":...} envelope —
    # different from the --json stdout format used by _call_codex.
    # Turn boundaries: event_msg{task_started} → event_msg{task_complete}.
    # Agent text:      event_msg{agent_message}.payload.message
    # Tool calls:      response_item{function_call}.payload.name
    lines = session_path.read_text(encoding="utf-8").splitlines()

    turns: list[list[dict]] = []
    current: list[dict] | None = None

    for raw in lines:
        try:
            obj = json.loads(raw)
        except json.JSONDecodeError:
            continue
        t = obj.get("type", "")
        payload = obj.get("payload", {})

        if t == "event_msg":
            pt = payload.get("type", "")
            if pt == "task_started":
                current = []
            elif pt == "task_complete":
                if current is not None:
                    turns.append(current)
                current = None
            elif pt == "agent_message" and current is not None:
                current.append({"kind": "agent_message", "text": payload.get("message", "")})
        elif t == "response_item" and current is not None:
            if payload.get("type") == "function_call":
                current.append({"kind": "tool_call", "name": payload.get("name", "?")})

    if current:  # in-progress turn
        turns.append(current)

    if not turns:
        print("(no turns found in session)")
        return

    recent = turns[-n:]
    total = len(recent)
    for idx, items in enumerate(recent):
        offset = idx - total + 1
        label = f"[{offset:+d}]" if offset != 0 else "[last]"
        for item in items:
            if item["kind"] == "agent_message":
                text = item["text"]
                print(f"{label} assistant: {repr(text[:120])}")
            elif item["kind"] == "tool_call":
                print(f"{label} tool: {item['name']}")


def cmd_tail(argv: list[str]) -> None:
    n = 3
    agent_name = ""
    for arg in argv:
        if arg.startswith("-") and arg[1:].isdigit():
            n = int(arg[1:])
        elif not agent_name:
            agent_name = arg

    if not agent_name:
        print("Usage: ws-named-agent tail <name> [-<n>]", file=sys.stderr)
        sys.exit(1)

    registry_dir = _registry_dir()
    registry = _load_registry(registry_dir, agent_name)
    uuid = registry.get("uuid", "")
    backend = registry.get("backend") or infer_backend(registry.get("model") or "")

    if backend == "codex":
        codex_hits = list((Path.home() / ".codex" / "sessions").rglob(f"rollout-*-{uuid}.jsonl"))
        if not codex_hits:
            print(f"(no codex session found for {agent_name} / {uuid})", file=sys.stderr)
            sys.exit(1)
        _tail_codex(codex_hits[0], n)
    else:
        claude_hits = list((Path.home() / ".claude" / "projects").glob(f"*/{uuid}.jsonl"))
        if not claude_hits:
            print(f"(no claude session found for {agent_name} / {uuid})", file=sys.stderr)
            sys.exit(1)
        _tail_claude(claude_hits[0], n)


# ── Dispatch ──────────────────────────────────────────────────────────────────

COMMANDS = {
    "new":           cmd_new,
    "call":          cmd_call,
    "interrupt":     cmd_interrupt,
    "print":         cmd_print,
    "check-mailbox": cmd_check_mailbox,
    "override":      cmd_override,
    "tail":          cmd_tail,
}

if __name__ == "__main__":
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        cmds = "|".join(COMMANDS)
        print(f"Usage: ws-named-agent <{cmds}> ...", file=sys.stderr)
        sys.exit(1)
    COMMANDS[sys.argv[1]](sys.argv[2:])
