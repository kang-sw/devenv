#!/usr/bin/env python3
"""Spec health tool: strip legacy frontmatter fields and validate spec corpus.

Usage: ws-spec-build-index  (no arguments)

Scans all *.md files under ai-docs/spec/ recursively. Removes the
`features:` and `stems:` frontmatter blocks if present, then runs
cross-file health checks on the cleaned corpus.

Output:
  [fix] features: removed — <path>
  [warn] duplicate stem <stem> — found in <file1>, <file2>
  [warn] Implementation Gap (<date>) in <file> — <N> days old
  [warn] {#<stem>} in mental-model/<file> — no matching anchor in spec/
  [error] <path>: <message>
  (silent when file is already clean and passes all checks)
"""

import re
import sys
from collections import defaultdict
from datetime import date
from pathlib import Path


FRONTMATTER_DELIM = "---"


def parse_frontmatter_and_body(text: str) -> tuple[str, str]:
    """Split text into (frontmatter, body). Returns ('', text) if no frontmatter.

    Raises ValueError if opening --- has no closing ---.
    """
    if not text.startswith(FRONTMATTER_DELIM):
        return "", text
    try:
        end = text.index(FRONTMATTER_DELIM, len(FRONTMATTER_DELIM))
    except ValueError:
        raise ValueError("frontmatter opened with --- but no closing --- found")
    fm = text[len(FRONTMATTER_DELIM) : end].strip()
    body = text[end + len(FRONTMATTER_DELIM) :]
    return fm, body


def _replace_or_insert_block(lines: list[str], key: str, new_field_lines: list[str]) -> list[str]:
    """Replace or insert a YAML block identified by its key line.

    When new_field_lines is empty, removes the existing block if present.
    """
    start = None
    end = None
    for i, line in enumerate(lines):
        if line.startswith(f"{key}:"):
            start = i
            for j in range(i + 1, len(lines)):
                if lines[j] and not lines[j][0].isspace():
                    end = j
                    break
            if end is None:
                end = len(lines)
            break

    if start is not None:
        lines[start:end] = new_field_lines
    elif new_field_lines:
        if lines and lines[-1]:
            lines.append("")
        lines.extend(new_field_lines)

    return lines


def remove_features(fm: str) -> str:
    """Remove the features: block from frontmatter if present."""
    lines = fm.splitlines() if fm else []
    lines = _replace_or_insert_block(lines, "features", [])
    return "\n".join(lines)


def remove_stems(fm: str) -> str:
    """Remove the stems: block from frontmatter if present."""
    lines = fm.splitlines() if fm else []
    lines = _replace_or_insert_block(lines, "stems", [])
    return "\n".join(lines)


def process_file(path: Path) -> None:
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as e:
        print(f"[error] {path}: {e}", file=sys.stderr)
        return

    if not text.startswith(FRONTMATTER_DELIM):
        return

    try:
        fm, body = parse_frontmatter_and_body(text)
    except ValueError as e:
        print(f"[error] {path}: {e}", file=sys.stderr)
        return

    had_features = any(line.startswith("features:") for line in fm.splitlines())

    new_fm = remove_features(fm)
    new_fm = remove_stems(new_fm)
    new_fm = new_fm.strip()

    output = f"{FRONTMATTER_DELIM}\n{new_fm}\n{FRONTMATTER_DELIM}{body}"
    if output == text:
        return

    try:
        path.write_text(output, encoding="utf-8")
    except OSError as e:
        print(f"[error] {path}: {e}", file=sys.stderr)
        return

    if had_features:
        print(f"[fix] features: removed — {path}")


STEM_RE = re.compile(r'\{#(\d{6}-[\w-]+)\}')


def collect_stems(path: Path, body: str) -> list[str]:
    """Return all {#slug} anchors in body text, skipping fenced code blocks."""
    stems = []
    in_fence = False
    for line in body.splitlines():
        stripped = line.strip()
        if stripped.startswith("```"):
            in_fence = not in_fence
        if in_fence:
            continue
        stems.extend(STEM_RE.findall(line))
    return stems


def check_duplicate_stems(registry: dict[str, list[Path]]) -> None:
    for stem, paths in sorted(registry.items()):
        if len(paths) > 1:
            locations = ", ".join(str(p) for p in paths)
            print(f"[warn] duplicate stem {stem} — found in {locations}")


IMPL_GAP_RE = re.compile(r'> \[!note\] Implementation Gap · (\d{4}-\d{2}-\d{2})')
STALENESS_DAYS = 90


def check_implementation_gaps(paths: list[Path]) -> None:
    today = date.today()
    for path in paths:
        try:
            text = path.read_text(encoding="utf-8")
        except OSError:
            continue
        in_fence = False
        for line in text.splitlines():
            if line.strip().startswith("```"):
                in_fence = not in_fence
            if in_fence:
                continue
            m = IMPL_GAP_RE.search(line)
            if not m:
                continue
            try:
                gap_date = date.fromisoformat(m.group(1))
            except ValueError:
                continue
            age = (today - gap_date).days
            if age > STALENESS_DAYS:
                print(f"[warn] Implementation Gap ({m.group(1)}) in {path} — {age} days old")


def check_mental_model_refs(spec_registry: set[str], mental_model_dir: Path) -> None:
    if not mental_model_dir.is_dir():
        return
    for path in sorted(mental_model_dir.rglob("*.md")):
        try:
            text = path.read_text(encoding="utf-8")
        except OSError:
            continue
        in_fence = False
        for line in text.splitlines():
            if line.strip().startswith("```"):
                in_fence = not in_fence
            if in_fence:
                continue
            for stem in STEM_RE.findall(line):
                if stem not in spec_registry:
                    print(f"[warn] {{#{stem}}} in {path} — no matching anchor in spec/")


def main() -> None:
    sys.stdout.reconfigure(encoding="utf-8")
    if len(sys.argv) > 1:
        print(f"Usage: {sys.argv[0]}  (no arguments — scans ai-docs/spec/ automatically)", file=sys.stderr)
        sys.exit(1)

    spec_dir = Path("ai-docs/spec")
    if not spec_dir.is_dir():
        print(f"[error] {spec_dir} not found — run from the project root", file=sys.stderr)
        sys.exit(1)

    paths = sorted(spec_dir.rglob("*.md"))

    for path in paths:
        process_file(path)

    stem_registry: dict[str, list[Path]] = defaultdict(list)
    for path in paths:
        try:
            text = path.read_text(encoding="utf-8")
        except OSError:
            continue
        _, body = parse_frontmatter_and_body(text) if text.startswith(FRONTMATTER_DELIM) else ("", text)
        for stem in collect_stems(path, body):
            stem_registry[stem].append(path)

    check_duplicate_stems(stem_registry)
    check_implementation_gaps(paths)
    check_mental_model_refs(set(stem_registry.keys()), Path("ai-docs/mental-model"))


if __name__ == "__main__":
    main()
