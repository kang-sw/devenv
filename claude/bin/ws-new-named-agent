#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: ws-new-agent <agent-name> [--agent <type>] [--system-prompt <path>] [--model <opus|sonnet|haiku>]" >&2
  exit 1
fi

AGENT_NAME="$1"
shift

AGENT_TYPE=""
SYSTEM_PROMPT_PATH=""
MODEL=""
MODEL_EXPLICIT=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)
      AGENT_TYPE="$2"
      shift 2
      ;;
    --system-prompt)
      SYSTEM_PROMPT_PATH="$2"
      shift 2
      ;;
    --model)
      MODEL="$2"
      MODEL_EXPLICIT=1
      shift 2
      ;;
    *)
      echo "Unknown flag: $1" >&2
      exit 1
      ;;
  esac
done

# Default to sonnet only when no agent type is driving the model
if [[ "$MODEL_EXPLICIT" -eq 0 && -z "$AGENT_TYPE" ]]; then
  MODEL="sonnet"
fi

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
REPO_DIR_NAME=$(basename "$REPO_ROOT")
REGISTRY_DIR="$(git rev-parse --git-dir)/ws@$REPO_DIR_NAME/agents"
mkdir -p "$REGISTRY_DIR"

python3 - "$AGENT_NAME" "$MODEL" "$AGENT_TYPE" "$SYSTEM_PROMPT_PATH" "$REGISTRY_DIR" <<'PYEOF'
import json, uuid, sys, os

agent_name, model, agent_type, sp_path, registry_dir = sys.argv[1:]

system_prompt = open(sp_path).read() if sp_path else ""

data = {
    "uuid": str(uuid.uuid4()),
    "model": model,
    "agent_type": agent_type,
    "system_prompt": system_prompt,
    "token_count": 0,
    "compressed_at": False,
}

with open(os.path.join(registry_dir, agent_name + ".json"), "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PYEOF

# Write per-agent settings file with PostToolBatch mailbox hook
cat > "$REGISTRY_DIR/$AGENT_NAME.settings.json" <<'JSON'
{
  "hooks": {
    "PostToolBatch": [{
      "hooks": [{
        "type": "command",
        "command": "ws-agent-check-mailbox",
        "timeout": 5
      }]
    }]
  }
}
JSON

echo "Agent '$AGENT_NAME' registered"
