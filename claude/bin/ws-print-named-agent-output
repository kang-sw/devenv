#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: ws-print-named-agent-output <agent-name>" >&2
  exit 1
fi

AGENT_NAME="$1"
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
REPO_DIR_NAME=$(basename "$REPO_ROOT")
REGISTRY_DIR="$REPO_ROOT/.git/ws@$REPO_DIR_NAME/agents"
OUTPUT_PATH="$REGISTRY_DIR/$AGENT_NAME.output.txt"

if [[ ! -f "$OUTPUT_PATH" ]]; then
  echo "error: no output found for agent '$AGENT_NAME'" >&2
  exit 1
fi

cat "$OUTPUT_PATH"
