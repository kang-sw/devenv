#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if ! command -v jq &>/dev/null; then
  echo "error: jq is required but not found in PATH" >&2
  exit 1
fi

if [[ $# -lt 1 ]]; then
  echo "Usage: ws-call-agent <agent-name> <prompt>" >&2
  echo "       ws-call-agent <agent-name> - <<'PROMPT' ... PROMPT" >&2
  exit 1
fi

AGENT_NAME="$1"
if [[ $# -lt 2 || "$2" == "-" ]]; then
  PROMPT=$(cat)
else
  PROMPT="$2"
fi

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
REPO_DIR_NAME=$(basename "$REPO_ROOT")
REGISTRY_DIR="$(git rev-parse --git-dir)/ws@$REPO_DIR_NAME/agents"
AGENT_FILE="$REGISTRY_DIR/$AGENT_NAME.json"
OUTPUT_PATH="$REGISTRY_DIR/$AGENT_NAME.output.txt"
OUTBOX_FILE="$REGISTRY_DIR/$AGENT_NAME.outbox.txt"
SETTINGS_JSON=$(jq -nc --arg cmd "$SCRIPT_DIR/ws-agent-check-mailbox" \
  '{"hooks":{"PostToolBatch":[{"hooks":[{"type":"command","command":$cmd,"timeout":5}]}]}}')

if [[ ! -f "$AGENT_FILE" ]]; then
  echo "error: agent '$AGENT_NAME' not found — run ws-new-agent first" >&2
  exit 1
fi

UUID=$(jq -r '.uuid' "$AGENT_FILE")
MODEL=$(jq -r '.model' "$AGENT_FILE")
AGENT_TYPE=$(jq -r '.agent_type' "$AGENT_FILE")
SYSTEM_PROMPT=$(jq -r '.system_prompt' "$AGENT_FILE")
TOKEN_COUNT=$(jq -r '.token_count' "$AGENT_FILE")
COMPRESSED_AT=$(jq -r '.compressed_at' "$AGENT_FILE")

SKIP_COMPRESSION=0
if [[ "$COMPRESSED_AT" == "true" ]]; then
  jq '.compressed_at = false' "$AGENT_FILE" > "${AGENT_FILE}.tmp" && mv "${AGENT_FILE}.tmp" "$AGENT_FILE"
  SKIP_COMPRESSION=1
fi

TMPFILE=$(mktemp)
CLEANUP_FILES=("$TMPFILE")
cleanup() {
  rm -f "${CLEANUP_FILES[@]}"
}
trap cleanup EXIT

# Build base args for the main call
ARGS=(-p --dangerously-skip-permissions --output-format json)
if [[ -n "$MODEL" ]]; then
  ARGS+=(--model "$MODEL")
fi
if [[ -n "$AGENT_TYPE" ]]; then
  ARGS+=(--agent "$AGENT_TYPE")
fi
if [[ -n "$SYSTEM_PROMPT" ]]; then
  ARGS+=(--system-prompt "$SYSTEM_PROMPT")
fi
ARGS+=(--settings "$SETTINGS_JSON")

touch "$OUTBOX_FILE"
export WS_AGENT_OUTBOX="$OUTBOX_FILE"

# Session routing
ESCAPED=$(echo "$REPO_ROOT" | sed 's|/|-|g')
SESSION_FILE="$HOME/.claude/projects/$ESCAPED/$UUID.jsonl"
if [[ -f "$SESSION_FILE" ]]; then
  ARGS+=(--resume "$UUID")
else
  ARGS+=(--session-id "$UUID")
fi

ERRFILE=$(mktemp)
CLEANUP_FILES+=("$ERRFILE")
MAX_RETRIES=3
RETRY_DELAY=3
for attempt in $(seq 1 $MAX_RETRIES); do
  if claude "${ARGS[@]}" "$PROMPT" > "$TMPFILE" 2>"$ERRFILE"; then
    break
  fi
  if grep -q "already in use" "$ERRFILE" && [[ $attempt -lt $MAX_RETRIES ]]; then
    echo "[info] Session busy, retrying in ${RETRY_DELAY}s (attempt $attempt/$MAX_RETRIES)..." >&2
    sleep $RETRY_DELAY
  else
    cat "$ERRFILE" >&2
    exit 1
  fi
done

# Drain outbox: PostToolBatch hook exits 2 when messages are pending,
# stopping the agent cleanly. Resume with each pending message in turn.
DRAIN_ARGS=(-p --dangerously-skip-permissions --output-format json)
[[ -n "$MODEL" ]]       && DRAIN_ARGS+=(--model "$MODEL")
[[ -n "$AGENT_TYPE" ]]  && DRAIN_ARGS+=(--agent "$AGENT_TYPE")
[[ -n "$SYSTEM_PROMPT" ]] && DRAIN_ARGS+=(--system-prompt "$SYSTEM_PROMPT")
DRAIN_ARGS+=(--settings "$SETTINGS_JSON")
DRAIN_ARGS+=(--resume "$UUID")

while [[ -s "$OUTBOX_FILE" ]]; do
  PENDING=$(cat "$OUTBOX_FILE")
  truncate -s 0 "$OUTBOX_FILE"
  DRAIN_TMPFILE=$(mktemp)
  CLEANUP_FILES+=("$DRAIN_TMPFILE")
  claude "${DRAIN_ARGS[@]}" "$PENDING" > "$DRAIN_TMPFILE"
  cp "$DRAIN_TMPFILE" "$TMPFILE"
done

NEW_TOKENS=$(jq '.usage.input_tokens + .usage.cache_creation_input_tokens + .usage.output_tokens' "$TMPFILE")
jq --argjson t "$NEW_TOKENS" '.token_count = $t | ."context-window" = $t' "$AGENT_FILE" > "${AGENT_FILE}.tmp" \
  && mv "${AGENT_FILE}.tmp" "$AGENT_FILE"

if [[ "$NEW_TOKENS" -gt 120000 && "$SKIP_COMPRESSION" -eq 0 ]]; then
  echo "[info] Context threshold exceeded — compressing session..." >&2

  # Step a: Extract original-prompt intent via haiku (one-shot)
  INTENT_FILE=$(mktemp)
  CLEANUP_FILES+=("$INTENT_FILE")
  claude -p --dangerously-skip-permissions --output-format json \
    --model haiku \
    --system-prompt "Summarize the user's intent in 2-3 sentences. Do not perform the task." \
    "$PROMPT" > "$INTENT_FILE"
  INTENT_SUMMARY=$(jq -r '.result' "$INTENT_FILE")

  # Step b: Inject compression prompt into existing agent (forced resume)
  COMPRESSION_PROMPT=$(cat "$(ws-infra-path agent-compression.md)")
  COMP_ARGS=(-p --dangerously-skip-permissions --output-format json)
  if [[ -n "$MODEL" ]]; then
    COMP_ARGS+=(--model "$MODEL")
  fi
  if [[ -n "$AGENT_TYPE" ]]; then
    COMP_ARGS+=(--agent "$AGENT_TYPE")
  fi
  if [[ -n "$SYSTEM_PROMPT" ]]; then
    COMP_ARGS+=(--system-prompt "$SYSTEM_PROMPT")
  fi
  COMP_ARGS+=(--settings "$SETTINGS_JSON")
  COMP_ARGS+=(--resume "$UUID")

  COMP_FILE=$(mktemp)
  CLEANUP_FILES+=("$COMP_FILE")
  claude "${COMP_ARGS[@]}" "$COMPRESSION_PROMPT" > "$COMP_FILE"
  COMPRESSION_DOC=$(jq -r '.result' "$COMP_FILE")

  # Step c: Spawn new agent with same config
  NEW_AGENT_ARGS=("$AGENT_NAME")
  if [[ -n "$MODEL" ]]; then
    NEW_AGENT_ARGS+=(--model "$MODEL")
  fi
  if [[ -n "$AGENT_TYPE" ]]; then
    NEW_AGENT_ARGS+=(--agent "$AGENT_TYPE")
  fi
  if [[ -n "$SYSTEM_PROMPT" ]]; then
    SP_FILE=$(mktemp)
    CLEANUP_FILES+=("$SP_FILE")
    printf '%s' "$SYSTEM_PROMPT" > "$SP_FILE"
    NEW_AGENT_ARGS+=(--system-prompt "$SP_FILE")
  fi
  "$SCRIPT_DIR/ws-new-named-agent" "${NEW_AGENT_ARGS[@]}"

  jq '.compressed_at = true' "$AGENT_FILE" > "${AGENT_FILE}.tmp" && mv "${AGENT_FILE}.tmp" "$AGENT_FILE"
  NEW_UUID=$(jq -r '.uuid' "$AGENT_FILE")

  # Carry over any pending interrupts so they survive the compaction handoff
  NEW_OUTBOX_FILE="$REGISTRY_DIR/$AGENT_NAME.outbox.txt"
  if [[ -s "$OUTBOX_FILE" ]]; then
    cat "$OUTBOX_FILE" >> "$NEW_OUTBOX_FILE"
    truncate -s 0 "$OUTBOX_FILE"
  fi

  # Step d: Handoff call to fresh agent
  HANDOFF_PROMPT="${COMPRESSION_DOC}

---

${INTENT_SUMMARY}

---

${PROMPT}"

  HANDOFF_ARGS=(-p --dangerously-skip-permissions --output-format json)
  if [[ -n "$MODEL" ]]; then
    HANDOFF_ARGS+=(--model "$MODEL")
  fi
  if [[ -n "$AGENT_TYPE" ]]; then
    HANDOFF_ARGS+=(--agent "$AGENT_TYPE")
  fi
  if [[ -n "$SYSTEM_PROMPT" ]]; then
    HANDOFF_ARGS+=(--system-prompt "$SYSTEM_PROMPT")
  fi
  HANDOFF_ARGS+=(--settings "$SETTINGS_JSON")
  HANDOFF_ARGS+=(--session-id "$NEW_UUID")

  HANDOFF_FILE=$(mktemp)
  CLEANUP_FILES+=("$HANDOFF_FILE")
  claude "${HANDOFF_ARGS[@]}" "$HANDOFF_PROMPT" > "$HANDOFF_FILE"

  HANDOFF_TOKENS=$(jq '.usage.input_tokens + .usage.cache_creation_input_tokens + .usage.output_tokens' "$HANDOFF_FILE")
  jq --argjson t "$HANDOFF_TOKENS" '.token_count = $t | ."context-window" = $t' "$AGENT_FILE" > "${AGENT_FILE}.tmp" \
    && mv "${AGENT_FILE}.tmp" "$AGENT_FILE"

  jq -r '.result' "$HANDOFF_FILE" | tee "$OUTPUT_PATH"
  if [[ "$(jq -r '.is_error' "$HANDOFF_FILE")" == "true" ]]; then
    exit 1
  fi
  exit 0
fi

jq -r '.result' "$TMPFILE" | tee "$OUTPUT_PATH"
if [[ "$(jq -r '.is_error' "$TMPFILE")" == "true" ]]; then
  exit 1
fi
